# this is used by iSH on iOS (set up using .profile)
alias pbcopy="cat > /dev/clipboard"
alias pbpaste="cat /dev/clipboard"

totp() { code=$(oathtool --totp -b "$(cat ~/.totp_${1})"); echo "$code"; echo "$code" > /dev/clipboard; }

eval "$(zoxide init posix --hook prompt)"


_bsync_confirm() {
  printf '%s (y/n): ' "$1"
  read reply
  [ "$reply" = "y" ]
}

_bsync_run() {
  rclone bisync "$1" "$2" \
    --check-access \
    --max-delete 20 \
    --conflict-resolve newer \
    --exclude ".DS_Store" \
    --exclude "._*" \
    --exclude ".Spotlight-V100" \
    --exclude ".Trashes" \
    --exclude ".fseventsd" \
    --exclude ".TemporaryItems" \
    --exclude "Thumbs.db" \
    --exclude "desktop.ini" \
    --exclude '$RECYCLE.BIN' \
    --exclude "System Volume Information" \
    -v \
    "$3" "$4" "$5" "$6"
}

bsync() {
  RESYNC=0
  if [ "$1" = "--resync" ]; then
    RESYNC=1
    shift
  fi

  LOCAL="$1"
  REMOTE="$2"

  # Preflight
  if ! command -v rclone >/dev/null 2>&1; then echo "rclone not found"; return 1; fi
  if [ ! -d "$LOCAL" ]; then echo "Local path missing: $LOCAL"; return 1; fi
  if ! rclone lsd "$REMOTE" >/dev/null 2>&1; then echo "Remote not accessible: $REMOTE"; return 1; fi

  # Ensure access sentinel exists on BOTH sides (required for --check-access)
  if [ ! -f "$LOCAL/RCLONE_TEST" ]; then
    echo "Creating RCLONE_TEST locally..."
    echo "rclone bisync access check" > "$LOCAL/RCLONE_TEST"
  fi

  # Copy it to remote if it doesn't exist there
  if ! rclone lsf "$REMOTE" | grep -q "^RCLONE_TEST$"; then
    echo "Creating RCLONE_TEST on remote..."
    rclone copyto "$LOCAL/RCLONE_TEST" "$REMOTE/RCLONE_TEST"
  fi

  # Resync mode
  if [ "$RESYNC" -eq 1 ]; then
    echo "=== Resync dry-run ==="
    _bsync_run "$LOCAL" "$REMOTE" --resync --dry-run || return 1
    _bsync_confirm "Run actual resync?" || { echo "Cancelled."; return 0; }
    echo "=== Resyncing ==="
    if _bsync_run "$LOCAL" "$REMOTE" --resync; then
      echo "✓ Done. Use 'bsync' from now on."
    else
      echo "ERROR."
    fi
    return
  fi

  # Normal sync: dry-run, summarise, confirm
  echo "=== Dry-run: $LOCAL <-> $REMOTE ==="
  out=$(_bsync_run "$LOCAL" "$REMOTE" --dry-run 2>&1)
  rc=$?
  echo "$out"

  printf '\n--- Summary ---\n'
  echo "Copy  -> remote : $(echo "$out" | grep -c "COPY.*$REMOTE")"
  echo "Copy  -> local  : $(echo "$out" | grep -c "COPY.*$LOCAL")"
  echo "Delete (remote): $(echo "$out" | grep -c "DELETE.*$REMOTE")"
  echo "Delete (local) : $(echo "$out" | grep -c "DELETE.*$LOCAL")"
  conflicts=$(echo "$out" | grep -c "conflict\|CONFLICT")
  if [ "$conflicts" -gt 0 ]; then echo "Conflicts      : $conflicts (keeping newer)"; fi

  if [ "$rc" -ne 0 ]; then
    echo "Dry-run failed (exit $rc). First run? Try: bsync --resync"
    return "$rc"
  fi
  if echo "$out" | grep -q "up to date\|No changes\|0 changes"; then
    echo "✓ Already in sync."
    return 0
  fi

  printf '\n'
  _bsync_confirm "Proceed with sync?" || { echo "Cancelled."; return 0; }
  echo "=== Syncing ==="
  if _bsync_run "$LOCAL" "$REMOTE"; then
    echo "✓ Done."
  else
    echo "ERROR."
    return 1
  fi
}
